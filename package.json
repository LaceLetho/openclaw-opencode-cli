{
  "name": "@laceletho/openclaw-opencode-cli",
  "version": "1.1.11",
  "description": "Command line tool for OpenClaw to dispatch tasks to OpenCode with async callback support",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "openclaw-opencode": "./bin/openclaw-opencode"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "start": "node ./dist/index.js"
  },
  "keywords": [
    "openclaw",
    "opencode",
    "cli",
    "ai",
    "agent"
  ],
  "author": "laceletho",
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/sdk": "^1.3.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}